FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=profesiones_wh
MYSQL_USER=whuser
MYSQL_PASSWORD=whpassword

# App DB URL (used by Flask app)
DATABASE_URL=mysql+pymysql://whuser:whpassword@db:3306/profesiones_wh

# For local dev without Docker:
# DATABASE_URL=mysql+pymysql://whuser:whpassword@localhost:3306/profesiones_wh

# Admin seed user
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# Upload folder (inside container)
UPLOAD_FOLDER=/app/uploads
MAX_CONTENT_LENGTH=52428800

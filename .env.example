FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=wft
MYSQL_USER=wftuser
MYSQL_PASSWORD=wftpassword

# App DB URL (used by Flask app)
DATABASE_URL=mysql+pymysql://wftuser:wftpassword@db:3306/wft

# For local dev without Docker:
# DATABASE_URL=mysql+pymysql://wftuser:wftpassword@localhost:3306/wft

# Admin seed user
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# Upload folder (inside container)
UPLOAD_FOLDER=/app/uploads
MAX_CONTENT_LENGTH=104857600

# Serve the app under a URL prefix (e.g. behind a shared domain with other
# apps at different paths, via Cloudflare Tunnel). Leave empty/unset to
# serve at the root - this is the case for local dev and staging.
# URL_PREFIX=/wft

# Set to 'prepro' only on the preprod VM's .env - gives the navbar a visibly
# different color + a banner, so it's never confused with production at a
# glance. Leave unset on production and local dev.
# APP_ENVIRONMENT=prepro
